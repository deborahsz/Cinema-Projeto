# Connection string do PostgreSQL (o docker-compose.yml na raiz do projeto já
# sobe um Postgres local com essas mesmas credenciais).
DATABASE_URL="postgresql://cinescope:cinescope@localhost:5432/cinescope?schema=public"

# Porta em que a API vai rodar.
PORT=3333

# Origem permitida pelo CORS (o frontend rodando com Vite).
CORS_ORIGIN="http://localhost:5173"

# Segredo usado para assinar os tokens JWT. Gere um valor aleatório forte,
# nunca reutilize o exemplo abaixo em produção.
JWT_SECRET="troque-por-um-segredo-aleatorio-bem-grande"
JWT_EXPIRES_IN="7d"
